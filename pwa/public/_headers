# Cloudflare Pages 보안 헤더
# https://developers.cloudflare.com/pages/configuration/headers/
# Vite가 public/ 파일을 dist/로 복사 → Pages가 이 파일을 자동으로 응답 헤더에 적용

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Permissions-Policy: geolocation=(), microphone=(self), camera=(), payment=(), usb=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; font-src 'self' https://cdn.jsdelivr.net data:; img-src 'self' data: blob: https:; connect-src 'self' https://tutor-manager-proxy.hisyisnis.workers.dev https://api.notion.com https://*.notion.so https://*.notion-static.com https://ntfy.sh; media-src 'self' blob: https:; worker-src 'self' blob:; manifest-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
